# ─── Base de datos ──────────────────────────────────────────────────────────
# Copiar de la app de negocios (misma DB)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=huevos_point
DB_USER=Cucu
DB_PASSWORD=

# ─── JWT ────────────────────────────────────────────────────────────────────
# CRÍTICO: DEBE ser el mismo JWT_SECRET que usa la app de negocios
# (necesario para que el auto-login cross-app funcione)
JWT_SECRET=huevos_point_jwt_secret_dev_2026
JWT_EXPIRES_IN=8h

# ─── CORS ───────────────────────────────────────────────────────────────────
# URL del frontend del Dashboard Maestro en Vercel
CORS_ORIGIN=https://huevos-point-maestro.vercel.app

# ─── App de negocios ─────────────────────────────────────────────────────────
# URL de la app de negocios para generar los links de auto-login
APP_URL=https://huevos-point-gcbg.vercel.app

# ─── API Pública de Huevos Point ─────────────────────────────────────────────
# Crear la key desde Huevos Point: POST /api/admin/api-keys con business_id y scopes read:all
# Ver documentación completa en: docs/public-api.md
HP_API_BASE_URL=https://huevos-point-gcbg.vercel.app/api/public/v1
HP_API_KEY=hp_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Node ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3002